#!/bin/bash
# ==============================================================================
# Bash replacement for the Python install-service tool.
# Scans /container/service for install scripts and executes them.
# ==============================================================================

SERVICE_DIR="/container/service"
INSTALL_FILENAME="install.sh"
PROCESS_FILENAME="process.sh"
NB_PROCESS=0

echo "install-service (Bash version)"

# 1. Run global install script if available
if [ -f "$SERVICE_DIR/$INSTALL_FILENAME" ]; then
    echo "Running global install: $SERVICE_DIR/$INSTALL_FILENAME"
    bash "$SERVICE_DIR/$INSTALL_FILENAME"
    rm -f "$SERVICE_DIR/$INSTALL_FILENAME"
fi

# 2. Process each service directory
# Sort to maintain the same behavior as the Python 'sorted(os.listdir)'
for dir in $(ls -d ${SERVICE_DIR}/*/ 2>/dev/null | sort); do
    # Run service-specific install script
    if [ -f "${dir}${INSTALL_FILENAME}" ]; then
        echo "Running service install: ${dir}${INSTALL_FILENAME}"
        bash "${dir}${INSTALL_FILENAME}"
        rm -f "${dir}${INSTALL_FILENAME}"
    fi

    # Count processes to determine if we need a multi-process stack (runit)
    if [ -f "${dir}${PROCESS_FILENAME}" ]; then
        ((NB_PROCESS++))
    fi
done

echo "$NB_PROCESS process(es) found."

# 3. Handle multiple processes (mimicking the original Osixia logic)
if [ "$NB_PROCESS" -gt 1 ]; then
    if [ ! -f "/container/multiple_process_stack_added" ]; then
        echo "Multiple processes detected. Adding stack..."
        # This calls your existing bash tool
        /container/tool/add-multiple-process-stack
        touch /container/multiple_process_stack_added
    fi
fi