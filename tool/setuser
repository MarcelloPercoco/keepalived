#!/bin/bash
# ==============================================================================
# Bash wrapper for su-exec to maintain compatibility with setuser.py syntax.
# Usage: setuser <username> <command> [args...]
# ==============================================================================

if [ "$#" -lt 2 ]; then
    echo "Usage: setuser <user> <command> [args...]"
    exit 1
fi

USER=$1
shift

# su-exec handles environment and signal proxying natively
exec su-exec "$USER" "$@"