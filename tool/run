#!/bin/bash
# ==============================================================================
# Improved Bash replacement for the Python 'run' tool.
# Handles YAML parsing and ensures variables are correctly exported.
# ==============================================================================

# Optimized YAML parser for simple flat files and lists
parse_yaml() {
    local prefix=$2
    local s='[[:space:]]*' w='[a-zA-Z0-9_]*' fs=$(echo @|tr @ '\032')
    sed -ne "s|^\($s\):|\1|" \
        -e "s|^\($s\)\($w\)$s:$s[\"']\(.*\)[\"']$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)\($w\)$s:$s\(.*\)$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)-$s\(.*\)$s\$|\1$fs$fs\2|p" $1 |
    awk -F$fs '{
        indent = length($1)/2;
        vname[indent] = $2;
        for (i in vname) {if (i > indent) {delete vname[i]}}
        if (length($3) > 0) {
            vn=""; for (i=0; i<indent; i++) {vn=(vn)(vname[i])("_")}
            if (length($2) == 0) {
                 print "export " vn vname[indent-1] "=\"$" vn vname[indent-1] " " $3 "\""
            } else {
                 print "export " vn $2 "=\"" $3 "\""
            }
        }
    }' | sed 's/_=/=/g'
}

# English comment: Set base directory to ensure relative paths work
export CONTAINER_SERVICE_DIR="/container/service"

# 1. Load environment variables
if [ -f "/container/environment/default.yaml" ]; then
    echo "Processing /container/environment/default.yaml..."
    # Evaluate the parsed variables
    eval $(parse_yaml /container/environment/default.yaml)
fi

# 2. Run startup scripts
# We use find to be more robust than ls
for startup_script in $(find /container/service -name "startup.sh" | sort); do
    echo "Running startup: $startup_script"
    # Execute in the current shell to keep env variables
    . "$startup_script"
done

# 3. Final process execution
NB_PROCESS=$(find /container/service -name "process.sh" | wc -l)

if [ "$NB_PROCESS" -gt 1 ]; then
    echo "Multiple processes detected. Starting runit..."
    exec /usr/bin/runsvdir -P /etc/service
else
    PROCESS_SCRIPT=$(find /container/service -name "process.sh")
    echo "Starting main process: $PROCESS_SCRIPT"
    # Added 2>&1 to force logs to stdout/stderr
    exec bash "$PROCESS_SCRIPT" 2>&1
fi