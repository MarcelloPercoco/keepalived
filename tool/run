#!/bin/bash
# ==============================================================================
# Bash replacement for the Python 'run' tool.
# Handles environment loading from YAML and service execution.
# ==============================================================================

# Simple YAML to Env parser (handles keys and simple lists)
parse_yaml() {
    local prefix=$2
    local s='[[:space:]]*' w='[a-zA-Z0-9_]*' fs=$(echo @|tr @ '\032')
    sed -ne "s|^\($s\):|\1|" \
        -e "s|^\($s\)\($w\)$s:$s[\"']\(.*\)[\"']$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)\($w\)$s:$s\(.*\)$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)-$s\(.*\)$s\$|\1$fs$fs\2|p" $1 |
    awk -F$fs '{
        indent = length($1)/2;
        vname[indent] = $2;
        for (i in vname) {if (i > indent) {delete vname[i]}}
        if (length($3) > 0) {
            vn=""; for (i=0; i<indent; i++) {vn=(vn)(vname[i])("_")}
            if (length($2) == 0) {
                 # List item: append to previous key
                 print "export " vn vname[indent-1] "=\"$" vn vname[indent-1] " " $3 "\""
            } else {
                 print "export " vn $2 "=\"" $3 "\""
            }
        }
    }' | sed 's/_=/=/g'
}

# 1. Load environment variables from default.yaml
if [ -f "/container/environment/default.yaml" ]; then
    echo "Processing /container/environment/default.yaml..."
    eval $(parse_yaml /container/environment/default.yaml)
fi

# 2. Run startup scripts
# These usually prepare the config files using the env variables loaded above
for startup_script in $(ls /container/service/*/startup.sh 2>/dev/null); do
    echo "Running startup: $startup_script"
    bash "$startup_script"
done

# 3. Determine if we use runit (multiple processes) or direct exec
NB_PROCESS=$(ls /container/service/*/process.sh 2>/dev/null | wc -l)

if [ "$NB_PROCESS" -gt 1 ]; then
    echo "Multiple processes detected. Starting runit..."
    exec /usr/bin/runsvdir -P /etc/service
else
    # Only one process (Keepalived)
    PROCESS_SCRIPT=$(ls /container/service/*/process.sh 2>/dev/null)
    echo "Starting main process: $PROCESS_SCRIPT"
    exec bash "$PROCESS_SCRIPT"
fi