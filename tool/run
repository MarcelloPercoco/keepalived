#!/bin/bash
# ==============================================================================
# Compatibility version of the Bash 'run' tool.
# Provides dummy functions to satisfy Osixia startup scripts.
# ==============================================================================

echo "--- Init system starting (Bash Compatibility Mode) ---"

# --- Compatibility Functions (Mocking Osixia tools) ---

# Mock log-helper: always returns false to avoid grep errors
log-helper() {
    return 1
}

# Mock debug function
debug() {
    echo "DEBUG: $*"
}

export -f log-helper
export -f debug

# --- YAML Parser ---
parse_yaml() {
    local s='[[:space:]]*' w='[a-zA-Z0-9_]*' fs=$(echo @|tr @ '\032')
    sed -ne "s|^\($s\)\($w\)$s:$s[\"']\(.*\)[\"']$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)\($w\)$s:$s\(.*\)$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)-$s\(.*\)$s\$|\1$fs$fs\2|p" $1 |
    awk -F$fs '{
        indent = length($1)/2;
        vname[indent] = $2;
        for (i in vname) {if (i > indent) {delete vname[i]}}
        if (length($3) > 0) {
            vn=""; for (i=0; i<indent; i++) {vn=(vn)(vname[i])("_")}
            if (length($2) == 0) {
                 print "export " vn vname[indent-1] "=\"${" vn vname[indent-1] ":-} " $3 "\""
            } else {
                 print "export " vn $2 "=\"" $3 "\""
            }
        }
    }'
}

# 1. Environment Setup
export KEEPALIVED_ASSETS_DIR="/container/service/keepalived/assets"
[ -f "/container/environment/default.yaml" ] && eval $(parse_yaml /container/environment/default.yaml)

# 2. Run Startup
if [ -f "/container/service/keepalived/startup.sh" ]; then
    echo "Running startup..."
    # IMPORTANT: we don't use 'set -e' here so a grep error doesn't kill the boot
    cd /container/service/keepalived
    . ./startup.sh
    echo "Startup finished."
fi

# 3. Launch Process
echo "Launching Keepalived..."
cd /container
exec /bin/bash /container/service/keepalived/process.sh 2>&1
